{
  "version": 2,
  "buildCommand": "pnpm --dir artifacts/admin-panel run build",
  "outputDirectory": "artifacts/admin-panel/.next",
  "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
