{
  "version": 2,
  "$schema": "https://vercel.com/schemas/vercel.json",
  "framework": "vite",
  "installCommand": "npm install -g pnpm@10.17.1 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --dir artifacts/towing-birmingham run build",
  "outputDirectory": "artifacts/towing-birmingham/dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
