{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');['package-lock.json','yarn.lock'].forEach(f=>{try{fs.unlinkSync(f)}catch{} });\"",
    "dev": "pnpm --dir artifacts/towing-birmingham run dev",
    "dev:towing-birmingham": "pnpm --dir artifacts/towing-birmingham run dev",
    "build": "pnpm --dir artifacts/towing-birmingham run build",
    "build:towing-birmingham": "pnpm --dir artifacts/towing-birmingham run build",
    "build:vercel": "pnpm --dir artifacts/towing-birmingham run build",
    "typecheck": "pnpm --dir artifacts/towing-birmingham run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.8.3"
  }
}
